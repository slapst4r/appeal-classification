# --- Python Bytecode & Cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual Environments ---
# It is critical to ignore your local environment
.venv/
venv/
env/
ENV/
bin/
lib/

# --- Environment & Secrets ---
# Never commit your .env files containing API keys or database credentials
.env
.env.*
!.env.example

# --- FastAPI/Uvicorn Specific ---
# If you log to files instead of stdout
*.log
log.txt

# --- Databases ---
# Local SQLite databases used for development
*.db
*.sqlite3

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Packaging & Distribution ---
dist/
build/
*.egg-info/